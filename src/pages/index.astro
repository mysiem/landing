---
import Layout from '../layouts/Layout.astro';
import LandingPage from '../components/LandingPage';
import { PublicNavBar } from '../components/PublicNavBar';
import { PublicStatusBar } from '../components/PublicStatusBar';
---

<Layout title="SIEM Platform">
  <div class="grid h-screen w-screen overflow-hidden" style="grid-template-columns: 48px 1fr; grid-template-rows: 1fr auto;">
    <PublicNavBar client:load />
    <main class="overflow-auto bg-background">
      <LandingPage client:load />
    </main>
    <PublicStatusBar client:load />
  </div>
</Layout>
